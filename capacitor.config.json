{
  "appId": "com.tisbroker.store",
  "appName": "TIS Broker",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "hostname": "localhost"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#D71920",
      "showSpinner": true,
      "iosSpinnerStyle": "small",
      "spinnerColor": "#ffffff",
      "splashFullScreen": true
    },
    "Keyboard": {
      "resize": "body",
      "keepShowable": true
    },
    "LocalNotifications": {
      "sound": "beep.wav"
    }
  }
}
